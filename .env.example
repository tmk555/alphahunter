# FMP_API_KEY=your_fmp_key_here              # https://financialmodelingprep.com (250 req/day free)
# ALPHA_VANTAGE_API_KEY=your_av_key_here     # https://www.alphavantage.co (25 req/day free)

# ─── Notification Channels ──────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
# TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNO
