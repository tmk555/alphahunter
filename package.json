{
  "name": "alpha-hunter",
  "version": "6.0.0",
  "description": "AI-powered trading intelligence — sectors, RS, trade setups, macro",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test 'test/**/*.test.js'",
