    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
